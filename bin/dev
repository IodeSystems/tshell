#!/usr/bin/env bash
source "$(dirname "$0")"/_init.sh

TARGET="${1-emptystring}"

run_setup() {
  if ! echo "$PATH" | grep -q '[:^]\./bin[:$]'; then
    echo "./bin should be on your path. If using bash, add it with 'export PATH=\$PATH:./bin' in your ~.bash_profile"
    exit 1
  fi

  unameOut="$(uname -s)"
  case "${unameOut}" in
  Linux*) setup_linux ;;
  Darwin*) setup_mac ;;
  *) echo "Unsupported system: ${unameOut}" && exit 1 ;;
  esac

  echo "All good, if you are still missing something, please add the installation hints to the setup command"
}

setup_linux() {
  if ! command -v gpg &>/dev/null; then
    echo Installing GPG
    sudo apt install gpg -y
  fi
}

setup_mac() {
  if ! hash brew &>/dev/null; then
    echo "Please install homebrew from brew.io"
    exit 1
  fi

  if brew config | grep -q 'CLT: N/A'; then
    xcode-select --install
  fi

  if ! hash gsed &>/dev/null; then
    brew install gsed
  fi

  if ! command -v gpg &>/dev/null; then
    echo Installing GPG
    brew install gpg -y
  fi
}

ensure_no_changes() {
  if [[ "$(git status --porcelain=v1 2>/dev/null | wc -l | awk '{print $1}')" != "0" ]]; then
    git status --porcelain=v1 2>/dev/null
    exit 1
  fi
}

version() {
  ./gradlew -q properties -p tshell | grep '^version:' | awk '{print $2}'
}

case $TARGET in
setup)
  run_setup
  ;;
ensure-no-changes)
  ensure_no_changes
  ;;
release)
  ./gradlew clean build
  ensure_no_changes
  $SED_COMMAND --in-place .git/config -e 's|https://github.com/|git@github.com:|'
  COMMIT="$(git rev-parse HEAD)"
  CURRENT_VERSION="$(version)"
  RELEASE_VERSION="${CURRENT_VERSION%-SNAPSHOT}"
  MAJOR_MINOR="$(echo "$RELEASE_VERSION" | cut -d '.' -f1,2)"
  BRANCH="v${MAJOR_MINOR}.x"
  if [[ -z "$(git branch --list "$BRANCH")" ]]; then
    BRANCH="main"
  fi
  echo "Checking out $BRANCH to release from..."
  git reset --hard "origin/$BRANCH"
  git pull

  CURRENT_COMMIT="$(git rev-parse HEAD)"
  if [[ ! "${COMMIT}" = "${CURRENT_COMMIT}" ]]; then
    echo "Cannot release, tip of $BRANCH has moved past here."
    exit 1
  fi

  ensure_no_changes
  echo "This commit is on tip of $BRANCH to release from..."

  echo "Setting release version ${RELEASE_VERSION}..."
  $SED_COMMAND --in-place build.gradle.kts -e "s/version = \"${CURRENT_VERSION}\"/version = \"${RELEASE_VERSION}\"/"
  git commit -am "Release new version: ${RELEASE_VERSION}"

  echo "Publishing ${RELEASE_VERSION}..."
  ./gradlew :tshell:publishMavenJavaPublicationToOssrhRepository

  echo "Tagging with ${RELEASE_VERSION}..."
  git tag "${RELEASE_VERSION}"
  git push origin "${RELEASE_VERSION}"

  echo "Bumping to next snapshot..."
  IFS='.' read -r MAJOR MINOR PATCH <<< "$RELEASE_VERSION"
  NEXT_PATCH=$((PATCH + 1))
  SNAPSHOT_VERSION="${MAJOR}.${MINOR}.${NEXT_PATCH}-SNAPSHOT"
  $SED_COMMAND --in-place build.gradle.kts -e "s/version = \"${RELEASE_VERSION}\"/version = \"${SNAPSHOT_VERSION}\"/"

  echo "Committing next snapshot..."
  git commit -am "Next development version ${SNAPSHOT_VERSION}"
  git push

  ;;
version)
  version
  ;;
*)
  echo "The 'dev' script is for tools that fit in the development workflow

Supported commands:
  setup             ensures your system is setup
  release           builds a release version and publishes it
  ensure-no-changes fails if changes are made
  version           prints the current version
"
  exit 1
  ;;
esac
